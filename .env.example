PORT=3583
MAX_JSON_BODY_BYTES=1048576
RUN_CANCELLATION_POLL_INTERVAL_MS=1000
SANDBOX_IDLE_TIMEOUT_SECONDS=900
SANDBOX_STOP_DELAY_SECONDS=60
SANDBOX_RETENTION_SECONDS=3600
RUN_MODE=all

# Local defaults use fake execution. For real Flue + Daytona, set:
# RUNNER=flue
# SANDBOX_PROVIDER=daytona
RUNNER=fake
SANDBOX_PROVIDER=fake

# Use bearer auth when running the web UI against a non-public API.
# Supported: none, bearer, session.
API_AUTH_MODE=bearer
API_BEARER_TOKEN=dev-secret
AUTH_STATIC_USERNAME=dev
AUTH_STATIC_PASSWORD=dev-secret
AUTH_SESSION_SECRET=replace-with-random-local-secret
AUTH_COOKIE_SECURE=false

APP_STORE=postgres
DATABASE_URL=postgres://flue:flue@localhost:5432/flue
TEST_DATABASE_URL=postgres://flue:flue@localhost:5432/flue_test

FLUE_SESSION_STORE=postgres

# Required when RUNNER=flue. Anthropic credentials are read by the model SDK.
FLUE_MODEL=anthropic/claude-haiku-4-5
ANTHROPIC_API_KEY=

# Required when SANDBOX_PROVIDER=daytona.
DAYTONA_API_KEY=
DAYTONA_API_URL=
DAYTONA_TARGET=
DAYTONA_IMAGE=
DAYTONA_SNAPSHOT=

# Slack integration. For local HTTPS emulation:
# pnpm api:portless:start
# pnpm api:emulate:slack
# For real Slack local testing, expose the API with ngrok or cloudflared and set
# the Slack Events request URL to https://<public-tunnel>/webhooks/slack/events.
SLACK_API_BASE_URL=https://slack.emulate.localhost/api
SLACK_SIGNING_SECRET=dev-slack-signing-secret
SLACK_BOT_TOKEN=xoxb-dev-token
# Slack is fail-closed when SLACK_SIGNING_SECRET is set. Configure at least one
# allowlist, or explicitly set UNSAFE_ALLOW_ALL_SLACK_IDS=true for local tests.
UNSAFE_ALLOW_ALL_SLACK_IDS=false
# Optional comma-separated allowlists. Empty means unrestricted for that dimension,
# but at least one allowlist is required unless UNSAFE_ALLOW_ALL_SLACK_IDS=true.
SLACK_ALLOWED_TEAM_IDS=
SLACK_ALLOWED_CHANNEL_IDS=
SLACK_ALLOWED_USER_IDS=

# GitHub App runtime access for private repo clone/push/PR operations.
GITHUB_API_BASE_URL=https://api.github.com
# Separate clone/web base URL for GitHub Enterprise or git-server/emulator tests.
GITHUB_CLONE_BASE_URL=https://github.com
GITHUB_APP_ID=
# Use a single-line key with \n escapes for env files, or provide real newlines in secrets managers.
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Optional comma-separated allowlist. Supports owner/repo and owner/* patterns.
GITHUB_ALLOWED_REPOSITORIES=
# Optional comma-separated webhook allowlists. Empty means unrestricted for that dimension.
UNSAFE_ALLOW_ALL_GITHUB_USERS_AND_ORGS=false
GITHUB_ALLOWED_USERS=
GITHUB_ALLOWED_ORGANIZATIONS=
# Comma-separated GitHub handles that must be tagged in issue/PR/comment/review text.
# Example: devdeputies. Required when GITHUB_WEBHOOK_SECRET is set.
GITHUB_TRIGGER_HANDLES=

# Used by the separate Vite web app.
VITE_API_BASE_URL=http://localhost:3583
