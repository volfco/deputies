{
  "name": "deputies",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "api:db:migrate": "pnpm --dir api db:migrate",
    "api:dev": "pnpm --dir api dev",
    "api:emulate:slack": "pnpm --dir api emulate:slack",
    "api:portless:start": "pnpm --dir api portless:start",
    "api:start": "pnpm --dir api start",
    "api:build": "pnpm --dir api build",
    "api:typecheck": "pnpm --dir api typecheck",
    "api:test": "pnpm --dir api test",
    "api:test:integration": "pnpm --dir api test:integration",
    "api:test:load": "pnpm --dir api test:load",
    "api:test:uat": "pnpm --dir api test:uat",
    "api:test:watch": "pnpm --dir api test:watch",
    "web:dev": "pnpm --dir web dev",
    "web:build": "pnpm --dir web build",
    "web:e2e": "pnpm --dir web e2e",
    "web:test": "pnpm --dir web test",
    "web:test:watch": "pnpm --dir web test:watch",
    "web:typecheck": "pnpm --dir web typecheck",
    "check": "pnpm api:typecheck && pnpm api:test && pnpm web:typecheck && pnpm web:test"
  }
}
