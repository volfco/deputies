{
  "name": "deputies",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "db:up": "docker compose -f deploy/local/docker-compose.yml up -d postgres",
    "db:down": "docker compose -f deploy/local/docker-compose.yml down",
    "auth:login:openai-codex": "pnpm --dir apps/api auth:login:openai-codex",
    "api:db:migrate": "pnpm --dir apps/api db:migrate",
    "api:dev": "pnpm --dir apps/api dev",
    "api:emulate:slack": "pnpm --dir apps/api emulate:slack",
    "api:portless:start": "pnpm --dir apps/api portless:start",
    "api:start": "pnpm --dir apps/api start",
    "api:build": "pnpm --dir apps/api build",
    "api:typecheck": "pnpm --dir apps/api typecheck",
    "api:test": "pnpm --dir apps/api test",
    "api:test:integration": "pnpm --dir apps/api test:integration",
    "api:test:load": "pnpm --dir apps/api test:load",
    "api:test:uat": "pnpm --dir apps/api test:uat",
    "api:test:watch": "pnpm --dir apps/api test:watch",
    "web:dev": "pnpm --dir apps/web dev",
    "web:build": "pnpm --dir apps/web build",
    "web:e2e": "pnpm --dir apps/web e2e",
    "web:test": "pnpm --dir apps/web test",
    "web:test:watch": "pnpm --dir apps/web test:watch",
    "web:typecheck": "pnpm --dir apps/web typecheck",
    "check": "pnpm api:typecheck && pnpm api:test && pnpm web:typecheck && pnpm web:test"
  }
}
