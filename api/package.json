{
  "name": "deputies-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:migrate": "tsx src/db/migrate.ts",
    "dev": "tsx watch src/index.ts",
    "emulate:slack": "emulate start --service slack --portless",
    "portless:start": "pnpm dlx portless proxy start",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:load": "vitest run --config vitest.load.config.ts",
    "test:uat": "vitest run --config vitest.uat.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@daytona/sdk": "^0.171.0",
    "@flue/sdk": "^0.3.10",
    "@hono/node-server": "^2.0.1",
    "hono": "^4.12.17",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "@types/pg": "^8.20.0",
    "emulate": "^0.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "vitest": "^4.0.0"
  }
}
