:{$PORT:5173} {
	root * /usr/share/caddy
	encode zstd gzip

	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	@api path /health /auth* /sessions* /events* /webhooks*
	handle @api {
		reverse_proxy {$API_UPSTREAM:http://api:3583}
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}
